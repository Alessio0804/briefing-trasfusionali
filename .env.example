# Copia in .env per i test locali (NON committare .env).
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-haiku-4-5-20251001

# Bot Telegram (da @BotFather) e canale di destinazione.
TELEGRAM_BOT_TOKEN=123456:ABC-...
# @nomecanale (pubblico) oppure -100xxxxxxxxxx (privato)
TELEGRAM_CHAT_ID=@notizie_trasfusionali

TIMEZONE=Europe/Rome
TARGET_HOUR=8
NEWS_WINDOW=14
MEMORY_DAYS=60
ALWAYS_POST=false
# true per generare subito un post nei test, ignorando l'orario.
BYPASS_TIME_GUARD=true
